{
  "name": "medsupp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && tsc -p tsconfig.api.json && vite build",
    "preview": "vite preview",
    "migrate:household": "node --env-file=.env.local scripts/migrate-medicines-to-household.mjs",
