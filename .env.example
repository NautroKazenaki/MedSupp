# Одноразовые параметры миграции. Они нужны только локально:
# MIGRATE_URL=https://<ваш-проект>.vercel.app
# Значение MIGRATE_SECRET должно совпадать с переменной в Vercel.
MIGRATE_URL=
MIGRATE_SECRET=

# Сгенерируйте длинную случайную строку (не меньше 32 символов).
SESSION_SECRET=

# Пользователи: USER_N_NAME + USER_N_PASSWORD_HASH + USER_N_HOUSEHOLD.
# Один и тот же HOUSEHOLD = общая аптечка. Разный HOUSEHOLD = отдельные данные.
# HOUSEHOLD: латиница, цифры, дефис или подчёркивание (например family, katya).

USER_1_NAME=Сергей
USER_1_PASSWORD_HASH=
USER_1_HOUSEHOLD=

USER_2_NAME=Дарья
USER_2_PASSWORD_HASH=
USER_2_HOUSEHOLD=

USER_3_NAME=Катя
USER_3_PASSWORD_HASH=
USER_3_HOUSEHOLD=

USER_4_NAME=Полина
USER_4_PASSWORD_HASH=
USER_4_HOUSEHOLD=

USER_5_NAME=Маргарита
USER_5_PASSWORD_HASH=
USER_5_HOUSEHOLD=
