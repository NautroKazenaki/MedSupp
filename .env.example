# Создаётся автоматически после подключения Blob Store в Vercel.
BLOB_READ_WRITE_TOKEN=

# Сгенерируйте длинную случайную строку (не меньше 32 символов).
SESSION_SECRET=

# Имена, которые будут вводиться на экране входа.
USER_1_NAME=Сергей
USER_2_NAME=Дарья

# bcrypt-хеши паролей, а не сами пароли.
USER_1_PASSWORD_HASH=
USER_2_PASSWORD_HASH=
